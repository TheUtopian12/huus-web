---
// src/components/CoverageMap.astro
---

<section id="cobertura" class="relative py-24 lg:py-36 bg-[#f3f4f6] border-t border-black/5 overflow-hidden">
  <!-- Subtle backglows -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-huus-thistle/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Header Block (Luxury minimal style) -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-16 lg:mb-24 gap-6 reveal reveal-fade-up">
      <div class="max-w-2xl">
        <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-neutral-400 font-bold mb-3 block">PRESENCIA CORPORATIVA</span>
        <h2 class="text-3xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tight leading-[0.95] text-huus-dark">
          INFRAESTRUCTURA SIN <br/> LÍMITES GEOGRÁFICOS
        </h2>
      </div>
      <p class="text-xs sm:text-sm text-neutral-500 max-w-sm font-light leading-relaxed">
        Nuestra red de fibra óptica propia y anillos redundantes de transporte conectan los centros logísticos e industriales más importantes del país con disponibilidad extrema.
      </p>
    </div>

    <!-- Main Section Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Left Column: Refined Interactive Stats Cards -->
      <div class="lg:col-span-5 flex flex-col gap-4 order-2 lg:order-1">
        
        <!-- Node Monterrey -->
        <button 
          class="node-trigger text-left p-6 rounded-2xl bg-white border border-black/5 hover:border-huus-thistle/30 transition-all duration-300 group/card relative overflow-hidden active-node reveal reveal-fade-right cursor-pointer shadow-sm"
          data-city="monterrey"
        >
          <div class="absolute top-0 left-0 w-0.5 h-full bg-transparent transition-all duration-300" id="bar-monterrey"></div>
          <div class="flex items-center justify-between mb-4">
            <h4 class="font-display text-base font-black text-huus-dark tracking-tight">MONTERREY HUB (HQ)</h4>
            <span class="text-[8px] font-mono tracking-widest text-emerald-500 flex items-center gap-1.5 uppercase font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
              <span class="w-1 h-1 rounded-full bg-emerald-500"></span> ONLINE
            </span>
          </div>
          <p class="text-xs text-neutral-500 mb-5 font-light leading-relaxed">
            Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt.
          </p>
          <div class="grid grid-cols-3 gap-4 border-t border-black/5 pt-4 text-left">
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">LATENCIA DALLAS</p>
              <p class="text-xs font-bold text-huus-dark font-mono">~11 ms</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">CAPACIDAD CORE</p>
              <p class="text-xs font-bold text-huus-thistle font-mono">400 Gbps</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">ACCESO</p>
              <p class="text-xs font-bold text-neutral-700">Fibra / Micro</p>
            </div>
          </div>
        </button>

        <!-- Node Querétaro -->
        <button 
          class="node-trigger text-left p-6 rounded-2xl bg-white border border-black/5 hover:border-huus-thistle/30 transition-all duration-300 group/card relative overflow-hidden reveal reveal-fade-right delay-100 cursor-pointer shadow-sm"
          data-city="queretaro"
        >
          <div class="absolute top-0 left-0 w-0.5 h-full bg-transparent transition-all duration-300" id="bar-queretaro"></div>
          <div class="flex items-center justify-between mb-4">
            <h4 class="font-display text-base font-black text-huus-dark tracking-tight">QUERÉTARO DC HUB</h4>
            <span class="text-[8px] font-mono tracking-widest text-emerald-500 flex items-center gap-1.5 uppercase font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
              <span class="w-1 h-1 rounded-full bg-emerald-500"></span> ONLINE
            </span>
          </div>
          <p class="text-xs text-neutral-500 mb-5 font-light leading-relaxed">
            Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod.
          </p>
          <div class="grid grid-cols-3 gap-4 border-t border-black/5 pt-4 text-left">
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">LATENCIA CDMX</p>
              <p class="text-xs font-bold text-huus-dark font-mono">~4 ms</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">CAPACIDAD CORE</p>
              <p class="text-xs font-bold text-huus-thistle font-mono">200 Gbps</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">ACCESO</p>
              <p class="text-xs font-bold text-neutral-700">Dark Fiber</p>
            </div>
          </div>
        </button>

        <!-- Node CDMX -->
        <button 
          class="node-trigger text-left p-6 rounded-2xl bg-white border border-black/5 hover:border-huus-thistle/30 transition-all duration-300 group/card relative overflow-hidden reveal reveal-fade-right delay-200 cursor-pointer shadow-sm"
          data-city="cdmx"
        >
          <div class="absolute top-0 left-0 w-0.5 h-full bg-transparent transition-all duration-300" id="bar-cdmx"></div>
          <div class="flex items-center justify-between mb-4">
            <h4 class="font-display text-base font-black text-huus-dark tracking-tight">CDMX METRO</h4>
            <span class="text-[8px] font-mono tracking-widest text-emerald-500 flex items-center gap-1.5 uppercase font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
              <span class="w-1 h-1 rounded-full bg-emerald-500"></span> ONLINE
            </span>
          </div>
          <p class="text-xs text-neutral-500 mb-5 font-light leading-relaxed">
            Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet.
          </p>
          <div class="grid grid-cols-3 gap-4 border-t border-black/5 pt-4 text-left">
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">LATENCIA LOCAL</p>
              <p class="text-xs font-bold text-huus-dark font-mono">~1 ms</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">CAPACIDAD CORE</p>
              <p class="text-xs font-bold text-huus-thistle font-mono">200 Gbps</p>
            </div>
            <div>
              <p class="text-[7px] font-mono uppercase tracking-wider text-neutral-400 mb-1">ACCESO</p>
              <p class="text-xs font-bold text-neutral-700">Fiber Optic</p>
            </div>
          </div>
        </button>

      </div>

      <!-- Right Column: Interactive Map -->
      <div class="lg:col-span-7 flex flex-col justify-center items-center order-1 lg:order-2 bg-white p-6 sm:p-8 rounded-2xl border border-black/5 aspect-[4/3] relative overflow-hidden reveal reveal-scale-up delay-100 shadow-lg">
        
        <!-- Architectural grid overlay -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.02)_1px,transparent_1px)] bg-[size:1.5rem_1.5rem] pointer-events-none"></div>

        <!-- The Interactive Map of Mexico -->
