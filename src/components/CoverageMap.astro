        <h3 class="text-2xl font-black text-huus-dark mb-2">¡Excelente! Tenemos cobertura</h3>
        <p class="text-sm text-neutral-500 font-light">
          Contamos con red de fibra óptica disponible en tu estado. Déjanos tus datos y un ingeniero especializado se pondrá en contacto contigo a la brevedad.
        </p>
      </div>

      <form class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Nombre</label>
            <input type="text" class="w-full bg-huus-bg border border-black/5 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-huus-thistle/50 transition-colors" placeholder="Tu nombre">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Empresa</label>
            <input type="text" class="w-full bg-huus-bg border border-black/5 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-huus-thistle/50 transition-colors" placeholder="Tu empresa">
          </div>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Correo Electrónico</label>
          <input type="email" class="w-full bg-huus-bg border border-black/5 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-huus-thistle/50 transition-colors" placeholder="correo@empresa.com">
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Mensaje o Requerimiento</label>
          <textarea rows="3" class="w-full bg-huus-bg border border-black/5 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-huus-thistle/50 transition-colors" placeholder="Detalla brevemente tu necesidad de conectividad..."></textarea>
        </div>
        
        <button type="button" class="modal-close-trigger w-full py-3.5 bg-huus-dark hover:bg-black text-white text-[11px] font-black uppercase tracking-[0.2em] rounded-xl transition-all shadow-md mt-2">
          ENVIAR MENSAJE
        </button>
      </form>
    </div>
  </div>

  <!-- Modal 2: Sin Cobertura (Fuera de zona) -->
  <div id="modal-sin-cobertura" class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <!-- Backdrop oscuro -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm modal-close-trigger cursor-pointer"></div>
    
    <!-- Contenido del modal -->
    <div class="relative bg-white w-[90%] max-w-sm rounded-2xl p-8 shadow-2xl transform scale-95 transition-transform duration-300 text-center">
      <!-- Botón cerrar -->
      <button class="modal-close-trigger absolute top-4 right-4 text-neutral-400 hover:text-huus-dark transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="mb-6 flex flex-col items-center">
        <div class="w-16 h-16 bg-neutral-100 rounded-full flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#6b7280" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5L21 3m0 0l-4.5 0M21 3v4.5" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-huus-dark mb-2">Fuera de Cobertura</h3>
        <p class="text-sm text-neutral-500 font-light">
          Lo sentimos, por el momento no tenemos cobertura directa en este estado. Estamos expandiendo nuestra red constantemente.
        </p>
      </div>

      <div class="bg-huus-bg rounded-xl p-5 mb-2">
        <p class="text-xs font-bold text-huus-dark mb-3">Déjanos tu correo para avisarte cuando lleguemos:</p>
        <div class="flex gap-2">
          <input type="email" class="w-full bg-white border border-black/5 rounded-lg px-3 py-2 text-sm focus:outline-none" placeholder="correo@empresa.com">
          <button type="button" class="modal-close-trigger px-4 bg-huus-thistle hover:bg-[#a600c3] text-white text-[10px] font-bold uppercase rounded-lg transition-colors">
            Avisar
          </button>
        </div>
      </div>
    </div>
  </div>

</section>

<!-- Inline CSS to animate line dashes representing data stream -->
<style>
  .network-link {
    stroke-dasharray: 8 8;
    animation: flowData 1.5s linear infinite;
  }
  
  @keyframes flowData {
    0% {
      stroke-dashoffset: 100;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  /* Custom active button styling */
  .active-node {
    background-color: #ffffff !important;
    border-color: #bc00dd !important;
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(188, 0, 221, 0.1);
  }
  .active-node h4 {
    color: #bc00dd !important;
  }
  .active-node #bar-monterrey {
    background-color: #bc00dd !important;
    width: 2.5px;
  }
  .active-node #bar-queretaro {
    background-color: #bc00dd !important;
    width: 2.5px;
  }
  .active-node #bar-cdmx {
    background-color: #bc00dd !important;
    width: 2.5px;
  }
</style>

<script>
  // Script to handle interactive link toggle between cards and map SVGs
  const triggers = document.querySelectorAll('.node-trigger');
  
  const nodeElements = {
    monterrey: {
      circle: document.getElementById('circle-monterrey'),
      text: document.getElementById('text-monterrey') || document.querySelector('[data-city="monterrey"] text'),
      bar: document.getElementById('bar-monterrey'),
      glow: document.getElementById('glow-monterrey'),
      links: ['link-mty-cdmx', 'link-mty-qro']
    },
    queretaro: {
      circle: document.getElementById('circle-queretaro'),
      text: document.getElementById('text-queretaro'),
      bar: document.getElementById('bar-queretaro'),
      glow: document.getElementById('glow-queretaro'),
      links: ['link-mty-qro', 'link-qro-cdmx']
    },
    cdmx: {
      circle: document.getElementById('circle-cdmx'),
      text: document.getElementById('text-cdmx'),
      bar: document.getElementById('bar-cdmx'),
      glow: document.getElementById('glow-cdmx'),
      links: ['link-mty-cdmx', 'link-qro-cdmx']
    }
  };

  // Real-time fake telemetry log streams to print into the digital terminal console
  const consoleDatabases = {
    monterrey: [
      "MONTERREY BACKBONE: SECURE CONNECTION",
      "ROUTE: MTY_HQ -> DALLAS_HUB_100G | OPTICAL LOSS: 0.00dB | RTT: 11.12ms",
      "METRO-RING-01 ACTIVE | TEMPERATURE: 19.5 C | POWER INFEED: STABLE"
    ],
    queretaro: [
      "QUERÉTARO DATA CENTER HUB: ACTIVE FEED",
      "ROUTE: QRO_ANILLO_OPTICO -> CDMX_CORE | STATUS: ONLINE | CAP: 200Gbps",
      "REDUNDANCY FEED: BACKUP CARRIER STANDBY READY | FAILOVER: SECURE"
    ],
    cdmx: [
      "CDMX METROPOLITAN RING TELEMETRY ACTIVE",
      "ROUTE: CDMX_CORE -> MTY_HQ_PRIMARY | FIBER LOSS: 0.12dB/km | RTT: 21.04ms",
      "ACTIVE SECURE FLOWS: FINANCIAL SECTOR SLA ENFORCED | RATE: OPTIMAL"
    ]
  };

  // Element handles for terminal console lines
  const consoleL1 = document.getElementById('console-line-1');
  const consoleL2 = document.getElementById('console-line-2');
  const consoleL3 = document.getElementById('console-line-3');

  function updateTelemetryConsole(city: 'monterrey' | 'queretaro' | 'cdmx') {
    const lines = consoleDatabases[city];
    if (consoleL1 && consoleL2 && consoleL3 && lines) {
      // Small typing fade animation
      [consoleL1, consoleL2, consoleL3].forEach((el, index) => {
        el.style.opacity = '0';
        setTimeout(() => {
          el.innerText = lines[index];
          el.style.opacity = '1';
        }, index * 80);
      });
    }
  }

  function selectCity(city: 'monterrey' | 'queretaro' | 'cdmx') {
    // Reset all cards styling
    triggers.forEach(tr => {
      tr.classList.remove('active-node');
      const dataCity = tr.getAttribute('data-city');
      const bar = document.getElementById(`bar-${dataCity}`);
      if (bar) {
        bar.style.backgroundColor = 'transparent';
        bar.style.width = '0px';
      }
    });

    // Reset all map node styles and links
    const links = ['link-mty-cdmx', 'link-mty-qro', 'link-qro-cdmx'];
    links.forEach(lId => {
      const l = document.getElementById(lId);
      if (l) {
        l.setAttribute('stroke', '#ac9fbb');
        l.setAttribute('stroke-width', '1.5');
        (l as HTMLElement).style.animationDuration = '1.5s';
      }
    });

    (Object.keys(nodeElements) as Array<'monterrey' | 'queretaro' | 'cdmx'>).forEach(key => {
      const el = nodeElements[key];
      if (el.circle) {
        el.circle.setAttribute('fill', '#ac9fbb');
        el.circle.classList.remove('scale-125');
      }
      if (el.text) {
        el.text.setAttribute('fill', '#64748b');
        el.text.classList.remove('font-extrabold');
      }
      if (el.glow) {
        el.glow.setAttribute('fill', 'rgba(188, 0, 221, 0.02)');
      }
    });

    // Activate selected card
    const activeTrigger = document.querySelector(`.node-trigger[data-city="${city}"]`);
    if (activeTrigger) {
      activeTrigger.classList.add('active-node');
      const bar = document.getElementById(`bar-${city}`);
      if (bar) {
        bar.style.backgroundColor = '#bc00dd';
        bar.style.width = '2.5px';
      }
    }

    // Activate selected map node
    const activeNode = nodeElements[city];
    if (activeNode) {
      if (activeNode.circle) {
        activeNode.circle.setAttribute('fill', '#bc00dd');
        activeNode.circle.classList.add('scale-125');
      }
      if (activeNode.text) {
        activeNode.text.setAttribute('fill', '#bc00dd');
        activeNode.text.classList.add('font-extrabold');
      }
      if (activeNode.glow) {
        activeNode.glow.setAttribute('fill', 'rgba(188, 0, 221, 0.15)');
      }

      // Highlight the connected fiber links on map
      activeNode.links.forEach(lId => {
        const l = document.getElementById(lId);
        if (l) {
          l.setAttribute('stroke', '#3b0764');
          l.setAttribute('stroke-width', '3');
          (l as HTMLElement).style.animationDuration = '0.7s'; // speed up data flow visually!
        }
      });
    }

    // Update real-time logs in console
    updateTelemetryConsole(city);
  }

  // Card Triggers click listeners
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const city = trigger.getAttribute('data-city') as 'monterrey' | 'queretaro' | 'cdmx';
      selectCity(city);
    });
  });

  // Map Node click listeners
  const mapNodes = document.querySelectorAll('.map-node');
  mapNodes.forEach(node => {
    node.addEventListener('click', () => {
      const city = node.getAttribute('data-city') as 'monterrey' | 'queretaro' | 'cdmx';
      selectCity(city);
    });
  });

  // Automatic slow telemetry loop just for premium dashboard feel
  let telemetryInterval: any;
  function startTelemetryConsoleLoop() {
    let currentLineIndex = 0;
    const additionalLines = [
      "POWER METRICS: ALL REGIONS STABLE...",
      "ROUTING FLOW INDEX: PACKET FAILURE RATE OPTIMAL (0%)",
      "CORE TEMPERATURES WITHIN LICENSED STANDARDS (20 C)",
      "OPTICAL TRANSMISSION FREQUENCY SECURE",
      "ACTIVE CONECTIVIDAD THREADS: 412,983 SECURE ENDPOINTS"
    ];

    telemetryInterval = setInterval(() => {
      // only update line 3 randomly to show active live streaming!
      if (consoleL3) {
        consoleL3.style.opacity = '0';
        setTimeout(() => {
          consoleL3.innerText = additionalLines[currentLineIndex];
          consoleL3.style.opacity = '1';
          currentLineIndex = (currentLineIndex + 1) % additionalLines.length;
        }, 150);
      }
    }, 4000);
  }

  // Start the console telemetry live simulation
  startTelemetryConsoleLoop();

  // --- MAP INTERACTION LOGIC (Modals) ---
  const mapPaths = document.querySelectorAll('.mx-state');
  const modalCobertura = document.getElementById('modal-cobertura');
  const modalSinCobertura = document.getElementById('modal-sin-cobertura');
  const closeTriggers = document.querySelectorAll('.modal-close-trigger');

  function openModal(modal) {
    if(!modal) return;
    modal.classList.remove('hidden');
    // Small delay to allow display:block to apply before changing opacity for transition
    setTimeout(() => {
      modal.classList.remove('opacity-0');
      const innerContent = modal.querySelector('.relative.bg-white');
      if (innerContent) innerContent.classList.remove('scale-95');
    }, 10);
  }

  function closeModal(modal) {
    if(!modal) return;
    modal.classList.add('opacity-0');
    const innerContent = modal.querySelector('.relative.bg-white');
    if (innerContent) innerContent.classList.add('scale-95');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300); // match transition duration
  }

  // Map clicks
  mapPaths.forEach(path => {
    path.addEventListener('click', (e) => {
      const hasCoverage = path.getAttribute('data-coverage');
      if (hasCoverage === 'true') {
        openModal(modalCobertura);
      } else {
        openModal(modalSinCobertura);
      }
    });
  });

  // Close triggers
  closeTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      closeModal(modalCobertura);
      closeModal(modalSinCobertura);
    });
  });
</script>
