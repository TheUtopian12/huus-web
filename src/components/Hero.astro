---
// src/components/Hero.astro
---

<section
  id="huus-plus"
  class="relative w-full h-screen overflow-hidden bg-[#0a001a]"
>
  <!-- 1. CANVAS BACKGROUND (Neural Network — Mouse Reactive) -->
  <div
    class="absolute inset-0 z-0 bg-gradient-to-br from-[#3b0968] via-[#1b024d] to-[#0a001a]"
  >
    <canvas id="network-canvas" class="w-full h-full"></canvas>
  </div>

  <!-- Dynamic mouse glow -->
  <div
    id="mouse-glow"
    class="absolute pointer-events-none z-5 w-[600px] h-[600px] rounded-full opacity-0 transition-opacity duration-700"
    style="background: radial-gradient(circle, rgba(109,40,217,0.15) 0%, rgba(217,70,239,0.05) 40%, transparent 70%); transform: translate(-50%, -50%);"
  >
  </div>

  <!-- 2. WHITE OVERLAY MASK (Static) -->
  <svg
    class="absolute inset-0 w-full h-full z-10 drop-shadow-[8px_8px_20px_rgba(0,0,0,0.4)] pointer-events-none"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMinYMin slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M0,0 L1440,0 L1440,120 C1320,150 1250,40 1150,60 C1050,80 1000,200 850,200 C700,200 550,500 450,600 C350,700 200,750 0,650 Z"
      fill="#ffffff"></path>
  </svg>

  <!-- 3. UI CONTENT LAYER -->
  <div
    id="hero-content"
    class="absolute inset-y-0 left-0 z-20 pointer-events-auto w-full md:w-1/2 flex flex-col justify-center pl-6 sm:pl-12 md:pl-24"
  >
    <!-- Main Hero Text -->
    <div class="max-w-md pr-4">
      <!-- Tiny brand badge -->
      <div class="reveal reveal-fade-up mb-6">
        <div
          class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-black/5 bg-white/90 backdrop-blur-xl shadow-sm hover:border-huus-violet/30 transition-colors duration-500 cursor-default"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-huus-violet opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-huus-violet"
            ></span>
          </span>
          <span
            class="font-mono text-[10px] uppercase tracking-[0.2em] text-huus-dark font-semibold"
            >Infraestructura Crítica Activa</span
          >
        </div>
      </div>

      <!-- Massive dynamic headline -->
      <h1
        class="reveal reveal-fade-up delay-100 font-display text-5xl sm:text-6xl md:text-7xl lg:text-[84px] font-bold tracking-tight leading-[1.05] text-huus-dark mb-6"
      >
        Velocidad <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-huus-violet via-huus-magenta to-huus-electric bg-[length:200%_auto] animate-[shimmer_5s_linear_infinite]"
          >sin concesiones.</span
        >
      </h1>

      <p
        class="reveal reveal-fade-up delay-200 text-sm sm:text-base text-neutral-500 max-w-md font-normal tracking-wide leading-relaxed mb-8"
      >
        Conectividad de misión crítica diseñada para empresas que exigen
        rendimiento absoluto. Experimenta nuestra red de fibra óptica con
        topología redundante y latencia ultrabaja.
      </p>

      <!-- Dual CTA Buttons -->
      <div
        class="reveal reveal-fade-up delay-300 flex flex-wrap items-center gap-4 mb-10"
      >
        <a
          href="#contacto"
          id="hero-cta-primary"
          class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-[14px] bg-huus-dark text-white text-sm font-semibold tracking-wide transition-all duration-300 hover:bg-black hover:shadow-[0_8px_30px_rgba(0,0,0,0.25)] active:scale-[0.98] relative overflow-hidden"
        >
          <span class="relative z-10">Solicitar Factibilidad</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-3.5 h-3.5 relative z-10 transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
          <div
            class="absolute inset-0 bg-gradient-to-r from-huus-violet to-huus-magenta opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
        </a>

        <a
          href="#contacto"
          id="hero-cta-secondary"
          class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-[14px] bg-white/10 backdrop-blur-sm border border-white/20 text-huus-dark text-sm font-semibold tracking-wide transition-all duration-300 hover:bg-white/20 hover:border-white/40 hover:shadow-[0_4px_20px_rgba(255,255,255,0.1)] active:scale-[0.98]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-4 h-4 transition-transform duration-300 group-hover:scale-110"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 01-7.108-7.108c-.145-.44.02-1.071.385-1.356l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path>
          </svg>
          Hablar con un Ingeniero
        </a>
      </div>

      <!-- Metrics Bar -->
      <div
        id="hero-metrics"
        class="reveal reveal-fade-up delay-400 w-full overflow-x-auto scrollbar-none"
      >
        <div class="flex flex-nowrap items-center gap-px min-w-max">
          <div
            class="metric-item flex flex-col items-center px-4 py-2.5 bg-[#120a21]/90 backdrop-blur-sm border border-white/10 rounded-l-2xl hover:bg-[#120a21] transition-all duration-300 cursor-default group"
          >
            <span
              class="font-mono text-sm font-black text-white group-hover:text-huus-magenta transition-colors duration-300"
              data-count="99.999"
              data-suffix="%"
              data-decimals="3">99.999%</span
            >
            <span
              class="font-mono text-[9px] uppercase tracking-[0.2em] text-white/40 mt-0.5"
              >SLA</span
            >
          </div>
          <div
            class="metric-item flex flex-col items-center px-4 py-2.5 bg-[#120a21]/90 backdrop-blur-sm border border-white/10 hover:bg-[#120a21] transition-all duration-300 cursor-default group"
          >
            <span
              class="font-mono text-sm font-black text-white group-hover:text-huus-magenta transition-colors duration-300"
              data-count="12000"
              data-prefix="+"
              data-suffix=" km">+12,000 km</span
            >
            <span
              class="font-mono text-[9px] uppercase tracking-[0.2em] text-white/40 mt-0.5"
              >Fibra</span
            >
          </div>
          <div
            class="metric-item flex flex-col items-center px-4 py-2.5 bg-[#120a21]/90 backdrop-blur-sm border border-white/10 hover:bg-[#120a21] transition-all duration-300 cursor-default group"
          >
            <span
              class="font-mono text-sm font-black text-white group-hover:text-huus-magenta transition-colors duration-300"
              >24/7</span
            >
            <span
              class="font-mono text-[9px] uppercase tracking-[0.2em] text-white/40 mt-0.5"
              >NOC</span
            >
          </div>
          <div
            class="metric-item flex flex-col items-center px-4 py-2.5 bg-[#120a21]/90 backdrop-blur-sm border border-white/10 rounded-r-2xl hover:bg-[#120a21] transition-all duration-300 cursor-default group"
          >
            <span
              class="font-mono text-sm font-black text-white group-hover:text-huus-magenta transition-colors duration-300"
              data-count="250"
              data-prefix="+">+250</span
            >
            <span
              class="font-mono text-[9px] uppercase tracking-[0.2em] text-white/40 mt-0.5"
              >Clientes</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 opacity-40 animate-bounce"
  >
    <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-white"
      >Scroll</span
    >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="white"
      class="w-4 h-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
    </svg>
  </div>
</section>

<!-- SCRIPT: Enhanced Canvas with Mouse Interaction + Parallax -->
<script>
  const canvas = document.getElementById("network-canvas") as HTMLCanvasElement;
  const mouseGlow = document.getElementById("mouse-glow") as HTMLDivElement;
  const heroContent = document.getElementById("hero-content") as HTMLDivElement;

  if (canvas) {
    const ctx = canvas.getContext("2d");

    if (ctx) {
      // Mouse position tracking
      let mouseX = -9999;
      let mouseY = -9999;
      let targetMouseX = -9999;
      let targetMouseY = -9999;
      let isMouseInHero = false;

      class Particle {
        x: number;
        y: number;
        ox: number; // origin x
        oy: number; // origin y
        vx: number;
        vy: number;
        size: number;
        color: string;

        constructor() {
          this.x = Math.random() * canvas.width;
          this.y = Math.random() * canvas.height;
          this.ox = this.x;
          this.oy = this.y;
          this.vx = (Math.random() - 0.5) * 0.5;
          this.vy = (Math.random() - 0.5) * 0.5;
          this.size = Math.random() * 2 + 1;
          const colors = [
            "rgba(217,70,239,",
            "rgba(109,40,217,",
            "rgba(14,165,233,",
          ];
          this.color = colors[Math.floor(Math.random() * colors.length)];
        }

        update() {
          // Mouse repulsion
          const dx = this.x - mouseX;
          const dy = this.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const repelRadius = 120;

          if (dist < repelRadius && isMouseInHero) {
            const force = (repelRadius - dist) / repelRadius;
            this.vx += (dx / dist) * force * 2;
            this.vy += (dy / dist) * force * 2;
          }

          // Damping + drift back to origin area
          this.vx *= 0.95;
          this.vy *= 0.95;
          this.vx += (Math.random() - 0.5) * 0.2;
          this.vy += (Math.random() - 0.5) * 0.2;

          this.x += this.vx;
          this.y += this.vy;

          // Boundary bounce
          if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
          if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

          this.x = Math.max(0, Math.min(canvas.width, this.x));
          this.y = Math.max(0, Math.min(canvas.height, this.y));
        }

        draw(ctx: CanvasRenderingContext2D) {
          const dx = this.x - mouseX;
          const dy = this.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const proximity = isMouseInHero ? Math.max(0, 1 - dist / 200) : 0;
          const alpha = 0.6 + proximity * 0.4;
          const size = this.size + proximity * 2;

          ctx.beginPath();
          ctx.arc(this.x, this.y, size, 0, Math.PI * 2);
          ctx.fillStyle = `${this.color}${alpha})`;
          ctx.fill();

          // Glow effect on nearby particles
          if (proximity > 0.3) {
            ctx.beginPath();
            ctx.arc(this.x, this.y, size * 2.5, 0, Math.PI * 2);
            ctx.fillStyle = `${this.color}${proximity * 0.15})`;
            ctx.fill();
          }
        }
      }

      // Data packet animation for connections
      interface DataPacket {
        from: number;
        to: number;
        progress: number;
        speed: number;
        alpha: number;
      }
      let dataPackets: DataPacket[] = [];
      let particles: Particle[] = [];
      const connectionDistance = 140;

      const initParticles = () => {
        particles = [];
        const numParticles = Math.floor((canvas.width * canvas.height) / 8000);
        for (let i = 0; i < numParticles; i++) particles.push(new Particle());
      };

      const resize = () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        initParticles();
      };

      window.addEventListener("resize", resize);

      // Mouse tracking
      const heroSection = document.getElementById("huus-plus");
      heroSection?.addEventListener("mousemove", (e) => {
        const rect = canvas.getBoundingClientRect();
        targetMouseX = e.clientX - rect.left;
        targetMouseY = e.clientY - rect.top;
        isMouseInHero = true;

        // Update glow position
        if (mouseGlow) {
          mouseGlow.style.left = `${e.clientX}px`;
          mouseGlow.style.top = `${e.clientY}px`;
          mouseGlow.style.opacity = "1";
        }

        // Parallax on hero content
        if (heroContent) {
          const centerX = window.innerWidth / 2;
          const centerY = window.innerHeight / 2;
          const offsetX = ((e.clientX - centerX) / centerX) * 8;
          const offsetY = ((e.clientY - centerY) / centerY) * 5;
          heroContent.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
          heroContent.style.transition =
            "transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
        }
      });

      heroSection?.addEventListener("mouseleave", () => {
        targetMouseX = -9999;
        targetMouseY = -9999;
        isMouseInHero = false;
        if (mouseGlow) mouseGlow.style.opacity = "0";
        if (heroContent) {
          heroContent.style.transform = "translate(0, 0)";
          heroContent.style.transition =
            "transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
        }
      });

      // Spawn data packets occasionally
      const spawnPacket = () => {
        if (particles.length < 2) return;
        const fromIdx = Math.floor(Math.random() * particles.length);
        let toIdx = fromIdx;
        while (toIdx === fromIdx)
          toIdx = Math.floor(Math.random() * particles.length);

        const dx = particles[fromIdx].x - particles[toIdx].x;
        const dy = particles[fromIdx].y - particles[toIdx].y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < connectionDistance) {
          dataPackets.push({
            from: fromIdx,
            to: toIdx,
            progress: 0,
            speed: 0.008 + Math.random() * 0.012,
            alpha: 0.9,
          });
        }
      };

      let packetTimer = 0;
      const animate = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Smooth mouse interpolation
        mouseX += (targetMouseX - mouseX) * 0.1;
        mouseY += (targetMouseY - mouseY) * 0.1;

        // Draw connections
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < connectionDistance) {
              const opacity = (1 - dist / connectionDistance) * 0.4;

              const gradient = ctx.createLinearGradient(
                particles[i].x,
                particles[i].y,
                particles[j].x,
                particles[j].y,
              );
              gradient.addColorStop(0, `rgba(217, 70, 239, ${opacity})`);
              gradient.addColorStop(1, `rgba(14, 165, 233, ${opacity})`);

              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = gradient;
              ctx.lineWidth = 0.8;
              ctx.stroke();
            }
          }
        }

        // Draw and update data packets
        dataPackets = dataPackets.filter((packet) => packet.progress <= 1);
        dataPackets.forEach((packet) => {
          const from = particles[packet.from];
          const to = particles[packet.to];
          if (!from || !to) return;

          const x = from.x + (to.x - from.x) * packet.progress;
          const y = from.y + (to.y - from.y) * packet.progress;

          // Packet glow
          const grad = ctx.createRadialGradient(x, y, 0, x, y, 6);
          grad.addColorStop(0, `rgba(217, 70, 239, ${packet.alpha})`);
          grad.addColorStop(1, "rgba(217, 70, 239, 0)");
          ctx.beginPath();
          ctx.arc(x, y, 6, 0, Math.PI * 2);
          ctx.fillStyle = grad;
          ctx.fill();

          // Packet dot
          ctx.beginPath();
          ctx.arc(x, y, 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${packet.alpha})`;
          ctx.fill();

          packet.progress += packet.speed;
        });

        // Spawn new packets
        packetTimer++;
        if (packetTimer > 30) {
          spawnPacket();
          packetTimer = 0;
        }

        // Update and draw particles
        particles.forEach((particle) => {
          particle.update();
          particle.draw(ctx);
        });

        requestAnimationFrame(animate);
      };

      resize();
      animate();
    }
  }

  // Metric counter animation
  const metricItems = document.querySelectorAll(".metric-item [data-count]");

  const animateCounter = (el: Element) => {
    const target = parseFloat(el.getAttribute("data-count") || "0");
    const prefix = el.getAttribute("data-prefix") || "";
    const suffix = el.getAttribute("data-suffix") || "";
    const decimals = parseInt(el.getAttribute("data-decimals") || "0");
    const duration = 1800;
    const start = performance.now();

    const tick = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
      const current = target * eased;

      if (decimals > 0) {
        el.textContent = `${prefix}${current.toFixed(decimals)}${suffix}`;
      } else {
        if (target > 1000) {
          el.textContent = `${prefix}${Math.floor(current).toLocaleString()}${suffix}`;
        } else {
          el.textContent = `${prefix}${Math.floor(current)}${suffix}`;
        }
      }

      if (progress < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  };

  const metricsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          metricItems.forEach((el) => animateCounter(el));
          metricsObserver.disconnect();
        }
      });
    },
    { threshold: 0.5 },
  );

  const metricsBar = document.getElementById("hero-metrics");
  if (metricsBar) metricsObserver.observe(metricsBar);
</script>
