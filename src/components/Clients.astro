---
// src/components/Clients.astro

// Client logos represented as SVG inline wordmarks for demo
const clients = [
  { name: "OXXO", sector: "Retail" },
  { name: "Cemex", sector: "Industria" },
  { name: "FEMSA", sector: "Bebidas" },
  { name: "Banorte", sector: "Finanzas" },
  { name: "Axtel", sector: "Telecom" },
  { name: "Vitro", sector: "Manufactura" },
  { name: "ALFA", sector: "Conglomerado" },
  { name: "GRUMA", sector: "Alimentos" },
  { name: "KUO", sector: "Industrial" },
  { name: "Nemak", sector: "Automotriz" },
  { name: "ARCA", sector: "Bebidas" },
  { name: "CYDSA", sector: "Química" },
];
---

<section id="clientes" class="relative py-20 lg:py-28 bg-white border-t border-black/[0.04] overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 50% at 50% 100%, rgba(109,40,217,0.03) 0%, transparent 70%);"></div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal reveal-fade-up">
      <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-neutral-400 font-bold mb-3 block">Clientes que confían</span>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-huus-dark mb-4">
        Líderes de industria eligen HUUS+
      </h2>
      <p class="text-sm text-neutral-500 max-w-xl mx-auto leading-relaxed">
        Más de 250 empresas en México han confiado su conectividad crítica a nuestra infraestructura de fibra óptica de última generación.
      </p>
    </div>

    <!-- Logos grid -->
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-px bg-black/[0.05] rounded-2xl overflow-hidden reveal reveal-fade-up delay-100">
      {clients.map((client, idx) => (
        <div
          class="client-logo-item group relative bg-white flex flex-col items-center justify-center gap-2 py-8 px-6 cursor-default hover:bg-neutral-50 transition-all duration-500 hover:z-10"
          style={`transition-delay: ${idx * 40}ms`}
        >
          <!-- Wordmark-style logo placeholder -->
          <div class="relative flex flex-col items-center">
            <!-- Logo text (grayscale by default, color on hover) -->
            <span
              class="font-display font-black text-lg tracking-tighter text-neutral-300 group-hover:text-huus-violet transition-all duration-500 group-hover:scale-110 transform select-none"
              style="filter: saturate(0); transition: filter 0.5s ease, color 0.5s ease, transform 0.3s ease;"
              onmouseover="this.style.filter='saturate(1)'"
              onmouseout="this.style.filter='saturate(0)'"
            >
              {client.name}
            </span>
            <span class="text-[9px] font-mono uppercase tracking-widest text-neutral-300 group-hover:text-neutral-400 transition-colors duration-500 mt-1">
              {client.sector}
            </span>
          </div>

          <!-- Subtle glow on hover -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded" style="background: radial-gradient(circle at 50% 50%, rgba(109,40,217,0.05) 0%, transparent 70%);"></div>
        </div>
      ))}
    </div>

    <!-- Social proof strip -->
    <div class="flex flex-wrap items-center justify-center gap-8 mt-14 reveal reveal-fade-up delay-200">
      <div class="flex items-center gap-3">
        <div class="flex -space-x-2">
          {['bg-huus-violet', 'bg-huus-magenta', 'bg-huus-electric', 'bg-emerald-500'].map(color => (
            <div class={`w-7 h-7 rounded-full ${color} border-2 border-white flex items-center justify-center`}>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="white" class="w-3 h-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
          ))}
        </div>
        <span class="text-sm text-neutral-500 font-light">+250 ingenieros de redes confían en HUUS+</span>
      </div>

      <div class="h-4 w-px bg-black/10 hidden sm:block"></div>

      <div class="flex items-center gap-2">
        {[1,2,3,4,5].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-400">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
          </svg>
        ))}
        <span class="text-sm text-neutral-500 font-light ml-1">4.9/5 satisfacción de clientes</span>
      </div>
    </div>
  </div>
</section>
