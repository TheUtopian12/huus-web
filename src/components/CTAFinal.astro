---
// src/components/CTAFinal.astro
---

<section id="cta-final" class="relative py-28 lg:py-40 bg-[#030008] overflow-hidden border-t border-white/[0.04]">
  <!-- Canvas background for tech effect -->
  <canvas id="cta-canvas" class="absolute inset-0 w-full h-full opacity-60"></canvas>

  <!-- Layered ambient glows -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-huus-violet/15 rounded-full blur-[150px]"></div>
    <div class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-huus-magenta/8 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/3 right-1/3 w-[300px] h-[300px] bg-huus-electric/8 rounded-full blur-[80px]"></div>
  </div>

  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(rgba(109,40,217,1) 1px, transparent 1px), linear-gradient(90deg, rgba(109,40,217,1) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Top border gradient -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-huus-violet/50 to-transparent"></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 lg:px-12 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-huus-violet/20 bg-huus-violet/10 backdrop-blur-sm mb-8 reveal reveal-fade-up">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/60 font-semibold">Red disponible — evaluación en 24 horas</span>
    </div>

    <!-- Headline -->
    <h2 class="reveal reveal-fade-up delay-100 text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-white leading-[1.05] mb-6 max-w-4xl mx-auto">
      ¿Tu negocio merece una<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-huus-violet via-huus-magenta to-huus-electric bg-[length:200%_auto] animate-[shimmer_4s_linear_infinite]">
        red sin compromisos?
      </span>
    </h2>

    <!-- Description -->
    <p class="reveal reveal-fade-up delay-200 text-base sm:text-lg text-white/50 max-w-xl mx-auto leading-relaxed mb-12 font-light">
      En 24 horas tenemos una evaluación técnica de factibilidad personalizada para tu empresa. Sin costos. Sin compromisos.
    </p>

    <!-- CTA buttons -->
    <div class="reveal reveal-fade-up delay-300 flex flex-wrap items-center justify-center gap-4 mb-16">
      <a
        href="#contacto"
        class="group relative inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-[16px] bg-white text-huus-dark font-bold text-sm tracking-wide transition-all duration-300 hover:shadow-[0_0_40px_rgba(255,255,255,0.15)] hover:scale-[1.03] active:scale-[0.97] overflow-hidden"
      >
        <span class="relative z-10 flex items-center gap-2.5">
          Solicitar Evaluación Gratuita
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-huus-violet/10 to-huus-magenta/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>

      <a
        href="tel:8004887835"
        class="group inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-[16px] border border-white/15 text-white font-semibold text-sm tracking-wide transition-all duration-300 hover:border-white/30 hover:bg-white/5 active:scale-[0.97]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transition-transform duration-300 group-hover:rotate-12">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 01-7.108-7.108c-.145-.44.02-1.071.385-1.356l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        800 HUUS TELECOM
      </a>
    </div>

    <!-- Trust indicators row -->
    <div class="reveal reveal-fade-up delay-400 flex flex-wrap items-center justify-center gap-8 border-t border-white/[0.06] pt-12">
      {[
        { label: "Sin contratos de largo plazo", icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { label: "Evaluación técnica gratuita", icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { label: "SLA garantizado en contrato", icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { label: "Ingenieros certificados 24/7", icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
      ].map(item => (
        <div class="flex items-center gap-2.5 text-white/40 hover:text-white/70 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-emerald-500">
            <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
          </svg>
          <span class="text-sm font-light">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // CTA background canvas — flowing lines
  const ctaCanvas = document.getElementById('cta-canvas') as HTMLCanvasElement;
  if (ctaCanvas) {
    const ctx = ctaCanvas.getContext('2d');
    if (ctx) {
      const resize = () => {
        ctaCanvas.width = ctaCanvas.offsetWidth;
        ctaCanvas.height = ctaCanvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize);

      interface Line {
        x: number;
        y: number;
        length: number;
        angle: number;
        speed: number;
        alpha: number;
        color: string;
      }

      const lines: Line[] = [];
      const colors = ['rgba(109,40,217,', 'rgba(217,70,239,', 'rgba(14,165,233,'];
      
      for (let i = 0; i < 20; i++) {
        lines.push({
          x: Math.random() * ctaCanvas.width,
          y: Math.random() * ctaCanvas.height,
          length: 80 + Math.random() * 200,
          angle: Math.random() * Math.PI * 2,
          speed: 0.003 + Math.random() * 0.005,
          alpha: 0.1 + Math.random() * 0.3,
          color: colors[Math.floor(Math.random() * colors.length)]
        });
      }

      let time = 0;
      const animateCta = () => {
        ctx.clearRect(0, 0, ctaCanvas.width, ctaCanvas.height);
        time += 0.01;

        lines.forEach(line => {
          line.angle += line.speed;
          const x2 = line.x + Math.cos(line.angle) * line.length;
          const y2 = line.y + Math.sin(line.angle) * line.length;

          const grad = ctx.createLinearGradient(line.x, line.y, x2, y2);
          grad.addColorStop(0, `${line.color}0)`);
          grad.addColorStop(0.5, `${line.color}${line.alpha})`);
          grad.addColorStop(1, `${line.color}0)`);

          ctx.beginPath();
          ctx.moveTo(line.x, line.y);
          ctx.lineTo(x2, y2);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1;
          ctx.stroke();

          // Slow drift
          line.x += Math.cos(line.angle * 0.3) * 0.2;
          line.y += Math.sin(line.angle * 0.3) * 0.2;

          // Wrap around
          if (line.x < -100) line.x = ctaCanvas.width + 100;
          if (line.x > ctaCanvas.width + 100) line.x = -100;
          if (line.y < -100) line.y = ctaCanvas.height + 100;
          if (line.y > ctaCanvas.height + 100) line.y = -100;
        });

        requestAnimationFrame(animateCta);
      };
      animateCta();
    }
  }
</script>
