---
// src/components/Footer.astro
---

<footer class="relative bg-[#030008] border-t border-white/[0.04] pt-20 pb-10 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[200px] bg-huus-violet/8 rounded-full blur-[80px] pointer-events-none"></div>
  <!-- Top gradient border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-huus-violet/30 to-transparent"></div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    
    <!-- Top Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16 lg:mb-20 reveal reveal-fade-up">

      <!-- Column 1: Brand Pitch -->
      <div class="lg:col-span-4 flex flex-col justify-between gap-10">
        <div>
          <span class="font-display text-2xl font-black tracking-widest text-white flex items-center mb-4">
            HUUS<span class="text-huus-violet ml-0.5">+</span>
          </span>
          <p class="text-sm text-white/40 font-light leading-relaxed max-w-sm mb-8">
            Estableciendo nuevos récords de latencia y confiabilidad en telecomunicaciones corporativas. Conectamos negocios líderes con infraestructura redundante del más alto nivel mundial.
          </p>

          <!-- Social Media Links -->
          <div class="flex items-center gap-3">
            <a href="#" aria-label="LinkedIn" class="group flex items-center justify-center w-9 h-9 rounded-xl border border-white/10 bg-white/5 hover:border-huus-violet/40 hover:bg-huus-violet/10 hover:scale-105 transition-all text-white/30 hover:text-huus-violet shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
              </svg>
            </a>
            <a href="#" aria-label="X" class="group flex items-center justify-center w-9 h-9 rounded-xl border border-white/10 bg-white/5 hover:border-huus-violet/40 hover:bg-huus-violet/10 hover:scale-105 transition-all text-white/30 hover:text-huus-violet shadow-sm">
              <span class="font-display text-[10px] font-black tracking-wider">X</span>
            </a>
            <a href="#" aria-label="YouTube" class="group flex items-center justify-center w-9 h-9 rounded-xl border border-white/10 bg-white/5 hover:border-huus-violet/40 hover:bg-huus-violet/10 hover:scale-105 transition-all text-white/30 hover:text-huus-violet shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Certifications block -->
        <div>
          <span class="text-[9px] font-mono uppercase tracking-[0.25em] text-white/25 font-bold mb-4 block">Certificaciones</span>
          <div class="flex flex-wrap gap-2">
            {['ISO 27001', 'SOC 2 Type II', 'NOC 24/7', 'Tier III+', 'CNBV'].map(cert => (
              <span class="inline-flex items-center px-2.5 py-1 rounded-md border border-white/10 bg-white/5 text-[9px] font-mono uppercase tracking-wider text-white/40 hover:border-huus-violet/30 hover:text-huus-violet/70 transition-all duration-300 cursor-default">
                {cert}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Column 2: Connectivity -->
      <div class="lg:col-span-2 lg:col-start-6">
        <h5 class="text-[9px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Conectividad</h5>
        <ul class="space-y-3.5 text-xs text-white/40 font-light">
          {[
            'Internet Dedicado',
            'Alta Disponibilidad',
            'Internet Pyme',
            'VPN / MPLS',
            'SD-WAN',
            'Internet Eventos',
          ].map(item => (
            <li>
              <a href="#soluciones" class="hover:text-white hover:translate-x-1 transition-all duration-300 inline-block">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Managed Services -->
      <div class="lg:col-span-2">
        <h5 class="text-[9px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Servicios Administrados</h5>
        <ul class="space-y-3.5 text-xs text-white/40 font-light">
          {[
            'Comunicaciones Unificadas',
            'Red WiFi Administrada',
            'Ciberseguridad SOC',
            'SD-WAN Inteligente',
            'Data Center Mty V',
            'Videovigilancia Cloud',
          ].map(item => (
            <li>
              <a href="#soluciones" class="hover:text-white hover:translate-x-1 transition-all duration-300 inline-block">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Support & Contact -->
      <div class="lg:col-span-2">
        <h5 class="text-[9px] font-bold uppercase tracking-[0.25em] text-white/25 mb-6">Soporte y NOC</h5>
        <ul class="space-y-3.5 text-xs text-white/40 font-light mb-8">
          {[
            { label: 'Portal de Clientes', href: '#' },
            { label: 'Estado de la Red', href: '#cobertura' },
            { label: 'Reportar Incidente', href: '#contacto' },
            { label: 'Documentación', href: '#' },
          ].map(item => (
            <li>
              <a href={item.href} class="hover:text-white hover:translate-x-1 transition-all duration-300 inline-block">
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Contact info -->
        <div class="space-y-3 pt-4 border-t border-white/[0.06]">
          <a href="tel:8004887835" class="flex items-center gap-2 text-xs text-white/40 hover:text-white transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5 group-hover:scale-110 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 01-7.108-7.108c-.145-.44.02-1.071.385-1.356l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            800 HUUS TELECOM
          </a>
          <a href="mailto:solutions@huus.com" class="flex items-center gap-2 text-xs text-white/40 hover:text-white transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5 group-hover:scale-110 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0l-7.5-4.615a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            solutions@huus.com
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/[0.05] pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <!-- NOC status -->
      <div class="flex items-center gap-2">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
        </span>
        <span class="text-[10px] font-mono text-white/25 uppercase tracking-widest">SLA Activo: 99.999%</span>
      </div>

      <p class="text-[11px] text-white/20 font-light">
        © 2026 HUUS Telecom Inc. Todos los derechos reservados.
      </p>

      <!-- Legal links -->
      <div class="flex flex-wrap items-center gap-6 text-[11px] text-white/25 font-light">
        <a href="#" class="hover:text-white/60 transition-colors">Aviso de Privacidad</a>
        <span class="text-white/10">•</span>
        <a href="#" class="hover:text-white/60 transition-colors">Términos y Condiciones</a>
        <span class="text-white/10">•</span>
        <a href="#" class="hover:text-white/60 transition-colors">SLA 99.999%</a>
      </div>
    </div>

  </div>

  <!-- Massive background watermark -->
  <div class="absolute bottom-0 left-0 w-full flex justify-center items-end pointer-events-none select-none opacity-[0.025] -z-10 translate-y-20">
    <span class="font-display text-[26vw] font-black uppercase tracking-widest text-white leading-none">
      HUUS
    </span>
  </div>
</footer>