---
// src/components/StatsCounter.astro

const stats = [
  { value: 99.999, suffix: "%", label: "SLA Garantizado", decimals: 3, prefix: "", description: "Tiempo de actividad contractual" },
  { value: 4, suffix: " ms", label: "Latencia Core", decimals: 0, prefix: "<", description: "Punto a punto en red troncal" },
  { value: 24, suffix: "/7", label: "Monitoreo NOC", decimals: 0, prefix: "", description: "Centro de operaciones activo" },
  { value: 100, suffix: " Gbps", label: "Capacidad Core", decimals: 0, prefix: "", description: "Ancho de banda troncal total" },
  { value: 250, suffix: "+", label: "Clientes Activos", decimals: 0, prefix: "", description: "Empresas confían en HUUS+" },
];
---

<section id="estadisticas" class="relative py-20 lg:py-28 bg-[#f7f7f8] border-t border-black/[0.04] overflow-hidden">
  <!-- Subtle top highlight line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[200px] h-[1px] bg-gradient-to-r from-transparent via-huus-violet/30 to-transparent"></div>
  
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, #6D28D9 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal reveal-fade-up">
      <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-neutral-400 font-bold mb-3 block">Métricas de Rendimiento</span>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-huus-dark">
        Números que respaldan la confianza
      </h2>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-px bg-black/[0.06] rounded-2xl overflow-hidden shadow-sm">
      {stats.map((stat, idx) => (
        <div
          class={`stat-item group relative bg-white flex flex-col items-center text-center px-6 py-10 hover:bg-neutral-50 transition-all duration-500 hover:-translate-y-0.5 ${idx === 0 ? 'rounded-tl-2xl rounded-bl-2xl' : ''} ${idx === stats.length - 1 ? 'rounded-tr-2xl rounded-br-2xl' : ''} col-span-1 ${idx === 4 ? 'col-span-2 sm:col-span-1' : ''}`}
          data-idx={idx}
        >
          <!-- Subtle top border accent on hover -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-gradient-to-r from-huus-violet to-huus-magenta group-hover:w-full transition-all duration-500 rounded-full"></div>
          
          <!-- Counter number -->
          <div class="mb-3">
            <span
              class="stat-number font-mono text-3xl sm:text-4xl lg:text-[42px] font-black text-huus-dark group-hover:text-huus-violet transition-colors duration-500 leading-none"
              data-count={stat.value}
              data-suffix={stat.suffix}
              data-prefix={stat.prefix}
              data-decimals={stat.decimals}
            >
              {stat.prefix}{stat.value}{stat.suffix}
            </span>
          </div>

          <!-- Label -->
          <span class="text-sm font-semibold text-huus-dark mb-1">{stat.label}</span>
          
          <!-- Description -->
          <span class="text-[11px] text-neutral-400 font-light leading-tight max-w-[120px]">{stat.description}</span>

          <!-- Glow on hover -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(circle at 50% 0%, rgba(109,40,217,0.04) 0%, transparent 60%);"></div>
        </div>
      ))}
    </div>

    <!-- Trust badges row -->
    <div class="flex flex-wrap items-center justify-center gap-6 mt-12 reveal reveal-fade-up delay-300">
      {[
        { icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z", label: "ISO 27001" },
        { icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z", label: "Redundancia N+1" },
        { icon: "M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25", label: "NOC 24/7/365" },
        { icon: "M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z", label: "SOC Tier 3" },
        { icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", label: "SLA Garantizado" },
      ].map(badge => (
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-black/5 shadow-sm hover:border-huus-violet/20 transition-all duration-300 cursor-default group">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-huus-violet group-hover:scale-110 transition-transform duration-300">
            <path stroke-linecap="round" stroke-linejoin="round" d={badge.icon} />
          </svg>
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-wider">{badge.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const statsSection = document.getElementById('estadisticas');
  const statNumbers = document.querySelectorAll('.stat-number[data-count]');

  let animated = false;

  const runCounters = () => {
    if (animated) return;
    animated = true;

    statNumbers.forEach((el, i) => {
      const target = parseFloat(el.getAttribute('data-count') || '0');
      const suffix = el.getAttribute('data-suffix') || '';
      const prefix = el.getAttribute('data-prefix') || '';
      const decimals = parseInt(el.getAttribute('data-decimals') || '0');
      const duration = 2000;
      const delay = i * 100;

      setTimeout(() => {
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 4); // easeOutQuart
          const current = target * eased;

          if (decimals > 0) {
            el.textContent = `${prefix}${current.toFixed(decimals)}${suffix}`;
          } else {
            el.textContent = `${prefix}${Math.floor(current)}${suffix}`;
          }

          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }, delay);
    });
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        runCounters();
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  if (statsSection) observer.observe(statsSection);
</script>
