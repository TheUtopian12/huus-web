---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import StatsCounter from '../components/StatsCounter.astro';
import Solutions from '../components/Solutions.astro';
import Clients from '../components/Clients.astro';
import CoverageMap from '../components/CoverageMap.astro';
import SuccessCases from '../components/SuccessCases.astro';
import Contact from '../components/Contact.astro';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="HUUS+ | Redes Ópticas Ultra Premium y Servicios Administrados">
  <!-- Premium sticky navbar with scroll blur -->
  <Navbar />
  
  <main>
    <!-- Interactive Hero with particle network + parallax -->
    <Hero />
    
    <!-- Animated performance metrics counter -->
    <StatsCounter />
    
    <!-- Premium service catalog with icons and featured card -->
    <Solutions />

    <!-- Client logos grayscale → color on hover -->
    <Clients />
    
    <!-- Interactive coverage map with city tooltips -->
    <CoverageMap />

    <!-- Success cases with dark violet background -->
    <SuccessCases />
    
    <!-- Contact wizard form -->
    <Contact />

    <!-- Final CTA with tech background and violet lighting -->
    <CTAFinal />
  </main>
  
  <!-- Premium footer with black background and certifications -->
  <Footer />
</Layout>